# Self-hosted Convex env — paste into Coolify, fill real values. Do NOT commit secrets.

# Public origins (must match the domains pointed at yfn-1)
CONVEX_CLOUD_ORIGIN=https://convex-api.youngfounders.network
CONVEX_SITE_ORIGIN=https://convex-site.youngfounders.network
NEXT_PUBLIC_DEPLOYMENT_URL=https://convex-api.youngfounders.network

# Postgres — no db name in the URL
POSTGRES_URL=postgresql://convex:CHANGE_ME@<pg-container-name>:5432
DO_NOT_REQUIRE_SSL=1

# Instance identity — generate once, keep constant. INSTANCE_SECRET: openssl rand -hex 32
INSTANCE_NAME=ybudget-prod
INSTANCE_SECRET=CHANGE_ME_openssl_rand_hex_32

DISABLE_BEACON=true
REDACT_LOGS_TO_CLIENT=true
RUST_LOG=info

# Set on the deployment via `npx convex env set ...` after first deploy, NOT here:
#   JWT_PRIVATE_KEY, JWKS (from generateKeys.mjs)
#   SITE_URL=https://budget.youngfounders.network (frontend)
#   CONVEX_SITE_URL=https://convex-site.youngfounders.network
#   AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET, RESEND_API_KEY, OPENAI_API_KEY
